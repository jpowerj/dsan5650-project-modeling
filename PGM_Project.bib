@book{horowitz_ethnic_1985,
  title = {Ethnic {{Groups}} in {{Conflict}}},
  author = {Horowitz, Donald L.},
  date = {1985},
  publisher = {University of California Press},
  url = {https://www.dropbox.com/scl/fi/etmxzoif5wje82hrajl5i/Donald-L.-Horowitz-Ethnic-groups-in-conflict.pdf?rlkey=i4g0coeiggekeiffpagvovd3n&dl=1},
  abstract = {Based on his knowledge of ethnically divided societies in Asia, Africa, and the Caribbean, Horowitz contends that the spread of ethnic conflict is inversely related to the proliferation of democracy in developing societies. He examines the concept and foundations of ethnicity, and the causes of ethnic conflict such as envy among different groups, and efforts at secession from a national whole. He also answers such questions as: Why are ethnic affiliations conducive to severe conflict? Why is ethnic conflict more intense and violent in Asia and Africa than in Europe and North America? Why do political parties in severely divided societies split along ethnic lines? Why do ethnically based military coups frequently occur in developing countries just when their politics seem most competitive and democratic? He concludes with solutions to reduce the severity of ethnic conflict and to maximize interethnic cooperation. ISBN 0-520-05385-0: \$25.00.},
  isbn = {978-0-520-05880-4},
  langid = {english},
  pagetotal = {697},
  file = {/Users/jpj/Zotero/storage/AB8R9GBK/ Donald L. Horowitz - Ethnic groups in conflict (2000, University of California Press) - libgen.li.pdf}
}

